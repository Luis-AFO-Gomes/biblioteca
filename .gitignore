# =========================================================
# Django / Python project
# =========================================================

# ---------------------------------------------------------
# Python cache and compiled files
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ---------------------------------------------------------
# Virtual environments
# Recommended name: .venv
# These entries work across Windows, macOS and Linux
# ---------------------------------------------------------
.venv_bib/
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------
# Django local/runtime files
# Keep db.sqlite3 tracked on purpose, so it is NOT ignored
# ---------------------------------------------------------
*.log
local_settings.py

# Collected static files (generated by collectstatic)
staticfiles/

# Uploaded media files
media/

# ---------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------
# Test / coverage / tooling caches
# ---------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.pyre/
.dmypy.json

# ---------------------------------------------------------
# Jupyter
# ---------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------
.vscode/
.idea/

# ---------------------------------------------------------
# Operating system junk files
# ---------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini